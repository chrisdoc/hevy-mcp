{
	"name": "@hevy-mcp/hevy-client",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"import": "./src/types.ts"
		},
		"./schemas": {
			"types": "./src/schemas.ts",
			"import": "./src/schemas.ts"
		}
	},
	"scripts": {
		"build:client": "kubb generate --config ./kubb.config.ts",
		"check:types": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
