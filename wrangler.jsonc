{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hevy-mcp",
	"main": "packages/worker/src/worker.ts",
	"compatibility_date": "2026-07-11",
	"workers_dev": false,
	"preview_urls": true,
	"observability": {
		"traces": {
			"enabled": true,
      		"destinations": ["otel"]
		},
		"logs": {
			"enabled": true,
      		"destinations": ["otel-logs"]
		},
	},
	"kv_namespaces": [
		{
			"binding": "OAUTH_KV",
			"id": "4650aad553c0490ab50dbda88a70a7ec",
		},
	],
}
