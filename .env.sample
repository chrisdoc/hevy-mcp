HEVY_API_KEY=HEVY_KEY

# Sentry Configuration (optional - for source map uploads during build)
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# SENTRY_ORG=your_sentry_org_slug_here
# SENTRY_PROJECT=your_sentry_project_slug_here

# Honeycomb Configuration
# The API key is injected at build time from the HONEYCOMB_API_KEY GitHub
# secret via tsdown.config.ts. For local development, set it here:
# HONEYCOMB_API_KEY=your_honeycomb_api_key_here
